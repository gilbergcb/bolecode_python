# ============================================================
#  BOLECODE — Configuração de Ambiente
#  Copie para .env e preencha com os valores reais
# ============================================================

# --- Oracle / Winthor ---
ORACLE_HOST=192.168.1.253
ORACLE_PORT=1521
ORACLE_SERVICE=LOCAL
ORACLE_USER=LOCAL
ORACLE_PASSWORD=LOCAL
# Diretório do Oracle Instant Client (obrigatório para thick mode)
ORACLE_INSTANT_CLIENT_DIR=C:\oracle\instantclient_21_9

# --- Bradesco API ---
BRADESCO_ENV=sandbox
# sandbox: https://openapisandbox.prebanco.com.br
# producao: https://openapi.bradesco.com.br
BRADESCO_CLIENT_ID=seu_client_id
BRADESCO_CLIENT_SECRET=seu_client_secret

# Certificados mTLS (caminhos absolutos ou relativos a certs/)
BRADESCO_CERT_PEM=certs/bradesco.crt.pem
BRADESCO_KEY_PEM=certs/bradesco.key.pem
BRADESCO_CERT_PASSPHRASE=

# Dados do Beneficiário (do contrato Bradesco)
BRADESCO_NRO_CPF_CNPJ_BENEF=68542653     # CNPJ raiz 8 dígitos
BRADESCO_FIL_CPF_CNPJ_BENEF=1018          # filial 4 dígitos
BRADESCO_DIG_CPF_CNPJ_BENEF=38            # DV 2 dígitos
BRADESCO_CIDTFD_PROD_COBR=09              # carteira/produto
BRADESCO_CNEGOC_COBR=386100000000041000   # agência(4)+zeros(7)+conta(7)
BRADESCO_CESSPE_TITULO_COBR=25            # 25 = duplicata mercantil
BRADESCO_ALIAS_PIX=                        # chave PIX do beneficiario (EVP ou CNPJ)

# --- PIX Cobranca (COBV) ---
# Validade em dias apos vencimento (padrao 30, configuravel via Settings)
PIX_VALIDADE_APOS_VENCIMENTO=30

# --- Winthor / Filtros ---
WINTHOR_CODCOB=237
WINTHOR_CODFILIAL=1

# --- Jobs ---
SYNC_INTERVAL_SECONDS=30
MAX_TENTATIVAS=3

# --- Portal web (dashboard) ---
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8765
DASHBOARD_SECRET=troque_por_segredo_forte_aqui

# --- Segurança (AES-256-GCM p/ config sensível no banco) ---
ENCRYPTION_KEY=troque_por_32_chars_ou_mais_aqui__
